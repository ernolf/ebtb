${PATCH_BASHLIB:-_} && return
PATCH_BASHLIB=:

include_dirs() {
    # Get the PHP include directories (retrieved from php-config) and sort by length (longest first)
    ${X[php-config$php_version]} --includes | sed_ 's/-I//g' | ${X[tr]} ' ' '\n' | ${X[gawk]} '{ print length, $0 }' | ${X[sort]} -nr | ${X[cut]} -d" " -f2-
}

patch_84() {
    local files file headers header dir alt_header
    local -A bool

#    # Get the PHP include directories (retrieved from php-config) and sort by length (longest first)
#    include_dirs=$(${X[php-config$php_version]} --includes | sed_ 's/-I//g' | ${X[tr]} ' ' '\n' | ${X[gawk]} '{ print length, $0 }' | ${X[sort]} -nr | ${X[cut]} -d" " -f2-)

    # Find all source files that include PHP headers
    files=$(${X[grep]} -rl '#include [<"]' --include="*.c" --include="*.h" .)

    # Loop through each file to verify header paths
    for file in $files; do

        # Check for occurrences of php_rand.h and rename them to php_random.h
        sed_ 's|#include [<"](.*)/php_rand.h>|#include <\1/php_random.h>|g' "$file" '-i' && echo "Correcting php_rand.h to php_random.h in $file"
        sed_ 's|#include [<"](.*)/php_mt_rand.h>|#include <\1/php_random.h>|g' "$file" '-i' && echo "Correcting php_mt_rand.h to php_random.h in $file"

        # Replace php_rand() with php_mt_rand() in the source file https://github.com/php/php-src/commit/8cf8751533aa37479f8f2e229e407e9bf6025237
        sed_ 's/php_rand(/php_mt_rand(/g' "$file" '-i' && echo "Correcting php_rand() to php_mt_rand() in $file"

        # Replace deprecated PHP string functions with the new ones
        sed_ 's/php_strtoupper\(/zend_str_toupper(/g' "$file" '-i' && echo "Correcting php_strtoupper() to zend_str_toupper() in $file"
        sed_ 's/php_string_toupper\(/zend_string_toupper(/g' "$file" '-i' && echo "Correcting php_string_toupper() to zend_string_toupper() in $file"
        sed_ 's/php_strtolower\(/zend_str_tolower(/g' "$file" '-i' && echo "Correcting php_strtolower() to zend_str_tolower() in $file"
        sed_ 's/php_string_tolower\(/zend_string_tolower(/g' "$file" '-i' && echo "Correcting php_string_tolower() to zend_string_tolower() in $file"

        # Find all included headers in the source file
        headers=$(${X[grep]} -o '#include <[^>]\+>' "$file" | sed_ 's/#include <(.*)>/\1/')

        # Check each header file if it exists in one of the PHP include directories
        for header in $headers; do
            bool[found]=_
            for dir in $(include_dirs); do
                if [[ -f "$dir/$header" ]]; then
                    bool[found]=:
                    break
                fi
            done

            # If not found in the default path, try to find it in alternative directories
            if ! ${bool[found]}; then
                # Search in all directories for the header
                for dir in $(include_dirs); do
                    alt_header=$(find "$dir" -name "$(${X[basename]} "$header")" -print -quit)
                    if [[ -n "$alt_header" ]]; then
                        echo "Correcting $header to ${alt_header#$dir/} in $file"
                        sed_ "s|#include <$header>|#include <${alt_header#$dir/}>|" "$file" '-i'
                        break
                    fi
                done
            fi
        done
    done
}

patch_85() {
    local smart_string_dir smart_string_hdr files file

    # Re-create removed compatibility header if a source still expects it.
    smart_string_dir="$(include_dirs | ${X[grep]} '/ext$' | head -n1)"
    smart_string_hdr="$smart_string_dir/standard/php_smart_string.h"
    if [[ -n $smart_string_dir && ! -f $smart_string_hdr ]]; then
        echo '#include "Zend/zend_smart_string.h"' > "$smart_string_hdr"
    fi

    # Find candidate source files once.
    files=$(${X[grep]} -Rrl \
        --include="*.c" \
        --include="*.h" \
        --include="*.cc" \
        --include="*.cpp" \
        --include="*.m4" \
        -e 'zend_exception_get_default' \
        -e 'zend_get_error_exception' \
        -e 'zend_ce_exception()' \
        -e 'zend_ce_error_exception()' \
        -e 'php_smart_string\.h' \
        -e 'php_smart_string_public\.h' \
        -e 'IS_INTERNED(' \
        -e 'STR_EMPTY_ALLOC(' \
        -e '_STR_HEADER_SIZE' \
        -e 'STR_ALLOCA_ALLOC(' \
        -e 'STR_ALLOCA_INIT(' \
        -e 'STR_ALLOCA_FREE(' \
        . 2>/dev/null || :)

    for file in $files; do
        [[ -f $file ]] || continue

        if ${X[grep]} -q 'zend_exception_get_default\|zend_ce_exception()' "$file"; then
            sed_ 's/zend_exception_get_default[[:space:]]*\(\)/zend_ce_exception/g' "$file" '-i'
            sed_ 's/zend_ce_exception[[:space:]]*\(\)/zend_ce_exception/g' "$file" '-i' && echo "Correcting zend_exception_get_default() to zend_ce_exception in $file"
        fi
        if ${X[grep]} -q 'zend_get_error_exception\|zend_ce_error_exception()' "$file"; then
            sed_ 's/zend_get_error_exception[[:space:]]*\(\)/zend_ce_error_exception/g' "$file" '-i'
            sed_ 's/zend_ce_error_exception[[:space:]]*\(\)/zend_ce_error_exception/g' "$file" '-i' && echo "Correcting zend_get_error_exception() to zend_ce_error_exception in $file"
        fi
        if ${X[grep]} -q 'php_smart_string\.h' "$file"; then
            sed_ 's#ext/standard/php_smart_string\.h#Zend/zend_smart_string.h#g' "$file" '-i'
            sed_ 's#php_smart_string\.h#Zend/zend_smart_string.h#g' "$file" '-i' && echo "Correcting php_smart_string.h include in $file"
        fi
        if ${X[grep]} -q 'php_smart_string_public\.h' "$file"; then
            sed_ 's#ext/standard/php_smart_string_public\.h#Zend/zend_smart_string_public.h#g' "$file" '-i'
            sed_ 's#php_smart_string_public\.h#Zend/zend_smart_string_public.h#g' "$file" '-i' && echo "Correcting php_smart_string_public.h include in $file"
        fi
        if ${X[grep]} -q 'IS_INTERNED(' "$file"; then
            sed_ 's/IS_INTERNED[[:space:]]*\(/ZSTR_IS_INTERNED(/g' "$file" '-i' && echo "Correcting IS_INTERNED() to ZSTR_IS_INTERNED() in $file"
        fi
        if ${X[grep]} -q 'STR_EMPTY_ALLOC(' "$file"; then
            sed_ 's/STR_EMPTY_ALLOC[[:space:]]*\(/ZSTR_EMPTY_ALLOC(/g' "$file" '-i' && echo "Correcting STR_EMPTY_ALLOC() to ZSTR_EMPTY_ALLOC() in $file"
        fi
        if ${X[grep]} -q '_STR_HEADER_SIZE' "$file"; then
            sed_ 's/_STR_HEADER_SIZE/_ZSTR_HEADER_SIZE/g' "$file" '-i' && echo "Correcting _STR_HEADER_SIZE to _ZSTR_HEADER_SIZE in $file"
        fi
        if ${X[grep]} -q 'STR_ALLOCA_ALLOC(' "$file"; then
            sed_ 's/STR_ALLOCA_ALLOC[[:space:]]*\(/ZSTR_ALLOCA_ALLOC(/g' "$file" '-i' && echo "Correcting STR_ALLOCA_ALLOC() to ZSTR_ALLOCA_ALLOC() in $file"
        fi
        if ${X[grep]} -q 'STR_ALLOCA_INIT(' "$file"; then
            sed_ 's/STR_ALLOCA_INIT[[:space:]]*\(/ZSTR_ALLOCA_INIT(/g' "$file" '-i' && echo "Correcting STR_ALLOCA_INIT() to ZSTR_ALLOCA_INIT() in $file"
        fi
        if ${X[grep]} -q 'STR_ALLOCA_FREE(' "$file"; then
            sed_ 's/STR_ALLOCA_FREE[[:space:]]*\(/ZSTR_ALLOCA_FREE(/g' "$file" '-i' && echo "Correcting STR_ALLOCA_FREE() to ZSTR_ALLOCA_FREE() in $file"
        fi
    done
}

patch_code() {
    case $php_version in
       8.4) patch_84
            ;;
       8.5) patch_85
    esac
}

patch_m4(){
    if [ -n "$m4_patch" ]; then
        B; echo "- patching config.m4"; N
        sed_ "$m4_patch" 'config.m4' '-i'
    fi
}
